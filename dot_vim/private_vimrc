
" Solarized
syntax enable
set background=dark
colorscheme solarized

" Plugged - Plugin Mannager - Setup
call plug#begin('~/.vim/plugged')
Plug 'junegunn/goyo.vim'
Plug 'vim-nerdtree/nerdtree'
Plug 'plasticboy/vim-markdown'
Plug 'lervag/vimtex'
Plug 'ycm-core/YouCompleteMe'
"Plug 'garbas/vim-snipmate'
"Plug 'rbonvall/snipmate-snippets-bib'
"Plug 'honza/vim-snippets'
Plug 'osyo-manga/vim-over'
call plug#end()

"Man pages
runtime! ftplugin/man.vim

" Layout
set ls=2
set textwidth=80
set tabstop=4
set colorcolumn=80
set softtabstop=4
" set expandtab :: Uncomment to read tabs as spaces
set splitright splitbelow

"""Set statusline
set laststatus=2
set statusline=
set statusline+=%F
set statusline+=%=
set statusline+=%P
set statusline+=\
set statusline+=%l
set statusline+=:
set statusline+=:
set statusline+=%c
set statusline+=\
set statusline+=%y

" Custom Bindings
noremap <Up> <Nop>
noremap <Down> <Nop>
noremap <Left> <Nop>
noremap <Right> <Nop>
nnoremap  $
nnoremap   ^

" UI
set nocompatible
set number relativenumber
"shows typed commands bottom-leftCorner
set showcmd
set wildmenu
set showmatch
set foldmethod=indent

" Search
" highlights search patterns
set hlsearch
set incsearch
